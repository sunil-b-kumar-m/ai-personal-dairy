{
  "name": "ai-personal-diary",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered personal diary - fullstack monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "dev:client": "turbo run dev --filter=@diary/client",
    "dev:server": "turbo run dev --filter=@diary/server",
    "build:client": "turbo run build --filter=@diary/client",
    "build:server": "turbo run build --filter=@diary/server",
    "test": "turbo run test",
    "test:server": "turbo run test --filter=@diary/server",
    "test:client": "turbo run test --filter=@diary/client",
    "spell-check": "cspell \"**/*.{ts,tsx,md,json}\" --no-progress"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "cspell": "^9.7.0",
    "turbo": "^2.9.1"
  }
}
